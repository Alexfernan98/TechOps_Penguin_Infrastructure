generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  IT_ADMIN
  IT_TECH
  EMPLOYEE
  READ_ONLY
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  LOAN
  REPAIR
  DAMAGED
  RETIRED
  LOST
  IN_PRODUCTION
}

enum AssetCondition {
  GOOD
  FAIR
  POOR
  DAMAGED
}

enum TicketStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  PENDING_USER
  RESOLVED
  CLOSED
  REOPENED
  CANCELLED
}

enum TicketPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum TicketCategory {
  TECH_SUPPORT
  EQUIPMENT_REQUEST
  ACCESS_PERMISSIONS
  CONNECTIVITY
  SOFTWARE
  SECURITY
  OTHER
}

enum ActaType {
  DELIVERY
  RETURN
  RETIREMENT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  DELETE_LOGICAL
  ASSIGN
  UNASSIGN
  STATUS_CHANGE
  LOGIN
  LOGOUT
}

model User {
  id             String    @id @default(cuid())
  googleId       String?   @unique
  email          String    @unique
  name           String
  nameFirst      String?
  nameLast       String?
  ci             String?
  avatarUrl      String?
  role           Role      @default(EMPLOYEE)
  departmentSlug String?
  isActive       Boolean   @default(true)
  generic        Boolean   @default(false)
  notifPrefs     Json?
  googleAccessToken  String?   @db.Text
  googleRefreshToken String?   @db.Text
  googleTokenExpiry  DateTime?
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  assignedAssets  AssetAssignment[] @relation("AssignedToUser")
  managedAssets   AssetAssignment[] @relation("AssignedByUser")
  createdTickets  Ticket[]          @relation("TicketCreatedBy")
  assignedTickets Ticket[]          @relation("TicketAssignedTo")
  ticketComments  TicketComment[]
  actasAsFirmante Acta[]            @relation("ActaFirmante")
  actasAsReceptor Acta[]            @relation("ActaReceptor")
  auditLogs       AuditLog[]
  notifications   Notification[]
  csatResponses   CsatResponse[]

  @@index([email])
  @@index([departmentSlug])
  @@map("users")
}

model Location {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  siteCode  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  assets Asset[]

  @@map("locations")
}

model Department {
  id         String   @id @default(cuid())
  slug       String   @unique
  name       String
  parentSlug String?
  type       String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@map("departments")
}

model AssetCategory {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  tagPrefix String
  icon      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  assets Asset[]

  @@map("asset_categories")
}

model Asset {
  id                String         @id @default(cuid())
  tag               String         @unique
  barcode           String?        @unique
  categorySlug      String
  brand             String?
  model             String?
  serialNumber      String?        @unique
  imei              String?
  macWifi           String?
  macEth            String?
  operatingSystem   String?
  status            AssetStatus    @default(AVAILABLE)
  condition         AssetCondition @default(GOOD)
  departmentSlug    String?
  locationSlug      String?
  details           String?        @db.Text
  purchaseDate      DateTime?
  vendor            String?
  warrantyUntil     DateTime?
  accessories       String?        @db.Text
  evidenceFolderUrl String?
  shared            Boolean        @default(false)
  // Networking / CCTV / Servers (Sprint 1a)
  ipManagement      String?        // IP de gestión (switch, firewall, AP, cámara, server)
  internalCode      String?        // Código operativo interno (DC.H 120, A11, M14, etc.)
  nvrChannel        String?        // Canal NVR (D1-D32 o "Surveillance") — cámaras
  cameraType        String?        // PTZ / Turret / Bullet / Fisheye / Analog
  megapixels        Int?           // Solo cámaras
  ports             Int?           // # puertos físicos — switch / AP
  role              String?        // core / aggregation / distribution / access — sw; hypervisor / app / db — server
  haMode            String?        // active / passive — firewalls
  haPeerAssetId     String?        // referencia soft al peer en HA (no FK formal)
  displayLocation   String?        // Ubicación legible libre (ej. "PTZ Caseta Mara2", "Comedor Central-1")
  lastRevisionDate  DateTime?
  notes             String?        @db.Text
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  deletedAt         DateTime?

  category    AssetCategory     @relation(fields: [categorySlug], references: [slug])
  location    Location?         @relation(fields: [locationSlug], references: [slug])
  assignments AssetAssignment[]
  actas       Acta[]

  @@index([status])
  @@index([categorySlug])
  @@index([departmentSlug])
  @@index([warrantyUntil])
  @@index([deletedAt])
  @@map("assets")
}

model AssetAssignment {
  id           String    @id @default(cuid())
  assetId      String
  userId       String
  assignedById String
  assignedAt   DateTime  @default(now())
  returnedAt   DateTime?
  isPrimary    Boolean   @default(true)
  notes        String?   @db.Text

  asset      Asset @relation(fields: [assetId], references: [id])
  user       User  @relation("AssignedToUser", fields: [userId], references: [id])
  assignedBy User  @relation("AssignedByUser", fields: [assignedById], references: [id])

  @@index([assetId])
  @@index([userId])
  @@index([returnedAt])
  @@map("asset_assignments")
}

model Acta {
  id              String          @id @default(cuid())
  type            ActaType
  assetId         String
  receptorId      String
  firmanteId      String
  relatedActaId   String?
  pdfUrl          String?
  signedAt        DateTime        @default(now())
  conditionBefore AssetCondition?
  conditionAfter  AssetCondition?
  daysInUse       Int?
  observations    String?         @db.Text
  itDecision      String?
  metadata        Json?
  createdAt       DateTime        @default(now())

  asset       Asset  @relation(fields: [assetId], references: [id])
  receptor    User   @relation("ActaReceptor", fields: [receptorId], references: [id])
  firmante    User   @relation("ActaFirmante", fields: [firmanteId], references: [id])
  relatedActa Acta?  @relation("ActaRelacion", fields: [relatedActaId], references: [id])
  actasHijas  Acta[] @relation("ActaRelacion")

  @@index([assetId])
  @@index([receptorId])
  @@index([type])
  @@map("actas")
}

model Ticket {
  id           String         @id @default(cuid())
  number       String         @unique
  title        String
  description  String         @db.Text
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(MEDIUM)
  category     TicketCategory @default(TECH_SUPPORT)
  createdById  String
  assignedToId String?
  assetId      String?
  dueAt        DateTime?
  resolvedAt   DateTime?
  closedAt     DateTime?
  slaBreached  Boolean        @default(false)
  csatScore    Int?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  createdBy  User            @relation("TicketCreatedBy", fields: [createdById], references: [id])
  assignedTo User?           @relation("TicketAssignedTo", fields: [assignedToId], references: [id])
  comments   TicketComment[]
  csat       CsatResponse?

  @@index([status])
  @@index([priority])
  @@index([createdById])
  @@index([assignedToId])
  @@index([dueAt])
  @@map("tickets")
}

model TicketComment {
  id         String    @id @default(cuid())
  ticketId   String
  authorId   String
  body       String    @db.Text
  isInternal Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  ticket Ticket @relation(fields: [ticketId], references: [id])
  author User   @relation(fields: [authorId], references: [id])

  @@index([ticketId])
  @@map("ticket_comments")
}

model CsatResponse {
  id        String   @id @default(cuid())
  ticketId  String   @unique
  userId    String
  score     Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@map("csat_responses")
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  action     AuditAction
  entityType String
  entityId   String
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id         String    @id @default(cuid())
  userId     String
  title      String
  body       String
  type       String
  entityType String?
  entityId   String?
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, readAt])
  @@map("notifications")
}

// ── Almacén / Stock (Sprint 1b) ────────────────────────────────────────────────
// Grupo gestionable de ítems de stock (networking, fibra óptica, cctv, etc.).
model StockGroup {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  items StockItem[]

  @@map("stock_groups")
}

// Ítem de stock con cantidad. Si categorySlug != null es "convertible" (puede
// desplegarse a un Asset); si es null es consumible puro (cables, fichas, etc.).
model StockItem {
  id           String    @id @default(cuid())
  name         String
  groupSlug    String
  categorySlug String?
  brand        String?
  model        String?
  unit         String    @default("unidad")
  quantity     Int       @default(0)
  minQuantity  Int?
  location     String?
  notes        String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  group     StockGroup      @relation(fields: [groupSlug], references: [slug])
  movements StockMovement[]

  @@index([groupSlug])
  @@index([categorySlug])
  @@index([deletedAt])
  @@map("stock_items")
}

// Bitácora inmutable de movimientos de stock. delta +entrada / -salida.
model StockMovement {
  id          String   @id @default(cuid())
  stockItemId String
  delta       Int
  reason      String   // INITIAL / PURCHASE / DEPLOY / ADJUST / CONSUME / RETURN
  assetId     String?  // si un DEPLOY generó un activo (Sprint 1b-2)
  userId      String?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())

  stockItem StockItem @relation(fields: [stockItemId], references: [id])

  @@index([stockItemId])
  @@map("stock_movements")
}
