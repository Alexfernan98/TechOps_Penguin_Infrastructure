# ═══════════════════════════════════════════════════════════════
# TechOpsHub — Variables de entorno
# Copia este archivo como .env y completa los valores
# NUNCA commitees el archivo .env al repositorio
# ═══════════════════════════════════════════════════════════════

POSTGRES_PASSWORD=cambia_esta_password_segura
DATABASE_URL=postgresql://techops:cambia_esta_password_segura@postgres:5432/techopshub
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback
ALLOWED_DOMAIN=penguin.digital
FRONTEND_URL=http://localhost:3000
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=alexis.fernandez@penguin.digital
SMTP_PASS=
SMTP_FROM_NAME=TechOpsHub Penguin

# NODE_ENV=production fuerza cookies `secure: true` (solo HTTPS). Si servís la
# app por HTTP en la LAN (caso típico on-premise), dejá esto en `development`
# o setear secure=false explícitamente; con secure=true las cookies de sesión
# no se setean y los logins fallan silenciosos.
NODE_ENV=development
BACKEND_PORT=4000
UPLOAD_PATH=./uploads
MAX_FILE_SIZE_MB=10
VITE_API_URL=http://localhost:4000

# Carpetas de Drive donde se suben las actas firmadas. Cada IT_ADMIN sube con
# su propia cuenta Google (OAuth user, no service account) — debe tener Editor
# en las 3 carpetas. Los IDs salen de la URL: /folders/<ID>
DRIVE_FOLDER_DELIVERIES=
DRIVE_FOLDER_RETURNS=
DRIVE_FOLDER_RETIREMENTS=
